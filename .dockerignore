# Keep the build context to what the image build actually copies:
# pyproject.toml, README.md, LICENSE and src/.
.git
.venv
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/

# Development and documentation trees the image never needs.
tests/
docs/
scripts/
deploy/
Makefile
constraints.txt
CHANGELOG.md
Dockerfile
.dockerignore
.github/

# Local Muster working files (a project is mounted at run time, not baked in).
muster.yaml
sources/
output/
runs/
demo/
profile.json
mapping-review.yaml
muster.schedule
.muster-token
.DS_Store
