# Muster deployment environment — TEMPLATE.
#
# Copy this file to deploy/muster.env, fill in real values, and NEVER
# commit the copy: deploy/*.env is gitignored precisely so a real secret
# cannot land in history. Rotate anything that ever does.
#
# Secrets never live in muster.yaml — target sections there name these
# variables (e.g. dsn_env: MUSTER_PG_DSN) and the values are resolved from
# the environment at publish time, then redacted from all output.

# --- PostgreSQL service (consumed by the postgres container) -------------
POSTGRES_USER=muster
POSTGRES_PASSWORD=change-me
POSTGRES_DB=muster

# --- Muster publish target ------------------------------------------------
# The DSN muster.yaml's postgres target names via dsn_env. The host is the
# compose service name; user, password and database must match the values
# above.
MUSTER_PG_DSN=postgresql://muster:change-me@postgres:5432/muster

# --- Optional -------------------------------------------------------------
# Webhook notified when a scheduled run fails (http or https only).
#MUSTER_WEBHOOK_URL=https://alerts.example.com/hook

# API key for the opt-in LLM mapping assist; leave unset to keep the
# feature off.
#MUSTER_LLM_API_KEY=

# JSON log lines are already set in docker-compose.yaml; set it here
# instead if you run the container by hand.
#MUSTER_LOG_FORMAT=json
